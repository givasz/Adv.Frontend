# Copie para .env.local para desenvolvimento (opcional).
#
# Sem nenhuma variável, o app roda 100% no MOCK (localStorage) e a geração de bio
# tenta o Ollama local. Ele funciona sozinho, sem backend.
#
# Para apontar ao backend real (Render):
#   VITE_API_URL contém a URL base do backend. Se definida, a GERAÇÃO DE BIO já usa
#   a IA do backend (Claude), mesmo mantendo os perfis no localStorage.
# VITE_API_URL="https://seu-backend.onrender.com"
#
#   VITE_USE_REAL_API=true faz TODO o app (perfis, busca, etc.) usar o backend.
# VITE_USE_REAL_API="true"
#
# Modelo do Ollama no dev (quando não há backend):
# VITE_OLLAMA_MODEL="llama3.2:3b"
#
# Caminho da rota escondida do painel de moderação (sem barra inicial).
# Padrão: painel-mod-7fq3k9x2a → acesse em advoc.me/painel-mod-7fq3k9x2a.
# Troque por um valor só seu (a rota é noindex, mas mantenha-a não-óbvia).
# VITE_ADMIN_PATH="painel-mod-7fq3k9x2a"
